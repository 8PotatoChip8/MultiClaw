[Unit]
Description=OpenClaw Gateway Service
After=network.target

[Service]
User=employee
Group=employee
WorkingDirectory=/home/employee
Environment="OPENCLAW_GATEWAY_TOKEN={{OPENCLAW_GATEWAY_TOKEN}}"
ExecStart=/home/employee/.openclaw/bin/openclaw gateway start --blocking
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
