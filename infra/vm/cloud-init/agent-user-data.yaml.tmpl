#cloud-config
hostname: {{HOSTNAME}}

users:
  - name: employee
    groups: sudo
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: true

package_update: true
packages:
  - curl
  - ca-certificates
  - jq
  - git
  - build-essential
  - python3
  - python3-pip
  - python3-venv

write_files:
  - path: /home/employee/.openclaw/openclaw.json
    owner: employee:employee
    permissions: '0644'
    content: |
      {{OPENCLAW_JSON}}

  - path: /etc/systemd/system/openclaw-gateway.service
    content: |
      {{OPENCLAW_SERVICE}}

  - path: /etc/systemd/system/multiclaw-agentd.service
    content: |
      {{AGENTD_SERVICE}}

runcmd:
  # Install Node.js 20 LTS via NodeSource
  - curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
  - apt-get install -y nodejs

  # Download and run the custom OpenClaw install script from control-plane
  - curl -fsSL http://{{HOST_IP}}:8080/v1/scripts/install-openclaw.sh -o /tmp/install-openclaw.sh
  - HOST_IP={{HOST_IP}} AGENT_USER=employee bash /tmp/install-openclaw.sh

  # Download multiclaw-agentd sidecar from the control plane
  - curl -o /usr/local/bin/multiclaw-agentd http://{{HOST_IP}}:8080/v1/agentd/download/$(uname -m) || true
  - chmod +x /usr/local/bin/multiclaw-agentd || true

  # Reload systemd and start services
  - systemctl daemon-reload
  - systemctl enable --now openclaw-gateway.service
  - systemctl enable --now multiclaw-agentd.service
