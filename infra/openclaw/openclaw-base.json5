// OpenClaw base config template for MultiClaw agents
// Template variables: {{AGENT_NAME}}, {{AGENT_PORT}}, {{OLLAMA_URL}}, {{MODEL}}, {{GATEWAY_TOKEN}}
{
  gateway: {
    mode: "local",
    bind: "lan",
    port: {{AGENT_PORT}},
    auth: {
      mode: "token",
      token: "{{GATEWAY_TOKEN}}",
    },
    http: {
      endpoints: {
        responses: { enabled: true },
      },
    },
  },

  agents: {
    defaults: {
      model: {
        primary: "ollama/{{MODEL}}",
      },
      models: {
        "ollama/{{MODEL}}": { alias: "{{MODEL}}" },
      },
      workspace: "/workspace",
      // Skip onboarding bootstrap since we provide workspace files
      skipBootstrap: true,

      // Memory search: local embeddings (built-in GGUF, no external deps)
      memorySearch: {
        enabled: true,
        provider: "local",
      },

      // Compaction: flush durable notes before context truncation
      compaction: {
        memoryFlush: {
          enabled: true,
        },
      },
    },
  },

  // Session configuration
  session: {
    reset: {
      // Idle sessions reset after 2 hours (triggers session-memory hook → saves context)
      idleMinutes: 120,
    },
  },

  models: {
    mode: "replace",
    providers: {
      ollama: {
        baseUrl: "{{OLLAMA_URL}}/v1",
        apiKey: "ollama",
        api: "openai-completions",
        models: [
          {
            id: "{{MODEL}}",
            name: "{{MODEL}}",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 198000,
            maxTokens: 16384,
          },
        ],
      },
    },
  },

  tools: {
    // Allow core tools + memory tools
    allow: [
      "bash",
      "read",
      "write",
      "edit",
      "process",
      "sessions_list",
      "sessions_history",
      "sessions_send",
      "memory_search",
      "memory_get",
    ],
  },

  // Enable OpenClaw hooks
  hooks: {
    internal: {
      enabled: true,
      entries: {
        // Saves conversation context to workspace/memory/ on session reset
        "session-memory": { enabled: true },
        // Logs all command events to ~/.openclaw/logs/commands.log (JSONL)
        "command-logger": { enabled: true },
        // Runs BOOT.md instructions on gateway start
        "boot-md": { enabled: true },
      },
    },
  },

  // No external messaging channels — MultiClaw is the channel
  channels: {},
}
