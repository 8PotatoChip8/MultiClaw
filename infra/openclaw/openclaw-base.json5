// OpenClaw base config template for MultiClaw agents
// Template variables: {{AGENT_NAME}}, {{AGENT_PORT}}, {{OLLAMA_URL}}, {{MODEL}}, {{GATEWAY_TOKEN}}, {{MEMORY_SEARCH_LOCAL}}
{
  gateway: {
    mode: "local",
    bind: "lan",
    port: {{AGENT_PORT}},
    auth: {
      mode: "token",
      token: "{{GATEWAY_TOKEN}}",
    },
    http: {
      endpoints: {
        responses: { enabled: true },
      },
    },
  },

  agents: {
    defaults: {
      model: {
        primary: "ollama/{{MODEL}}",
        // Only one active run at a time across all sessions for this agent.
        // MultiClaw's control plane serializes messages per agent, so this
        // should never bottleneck — it's a safety net against ghost runs.
        maxConcurrent: 1,
      },
      models: {
        "ollama/{{MODEL}}": { alias: "{{MODEL}}" },
      },
      workspace: "/workspace",
      // Skip onboarding bootstrap since we provide workspace files
      skipBootstrap: true,

      // Disable OpenClaw's built-in heartbeat — MultiClaw control plane runs its own
      heartbeat: { every: "0m" },

      // Memory search: local embeddings
      // When the pre-downloaded GGUF is available, render_config injects modelPath
      // to skip the 328 MB download on first use. Otherwise OpenClaw downloads it.
      memorySearch: {
        enabled: true,
        provider: "local",
        {{MEMORY_SEARCH_LOCAL}}
        query: {
          hybrid: {
            enabled: true,
            vectorWeight: 0.7,
            textWeight: 0.3,
          },
        },
      },

      // Compaction: flush durable notes before context truncation
      compaction: {
        memoryFlush: {
          enabled: true,
        },
      },
    },
  },

  // Session configuration
  session: {
    reset: {
      // Idle sessions reset after 2 hours (triggers session-memory hook → saves context)
      idleMinutes: 120,
    },
  },

  models: {
    mode: "replace",
    providers: {
      ollama: {
        baseUrl: "{{OLLAMA_URL}}/v1",
        apiKey: "ollama",
        api: "openai-completions",
        models: [
          {
            id: "{{MODEL}}",
            name: "{{MODEL}}",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 198000,
            maxTokens: 16384,
          },
        ],
      },
    },
  },

  tools: {
    // Allow core tools + memory tools
    allow: [
      "bash",
      "read",
      "write",
      "edit",
      "process",
      "memory_search",
      "memory_get",
    ],
  },

  // Enable OpenClaw hooks
  hooks: {
    internal: {
      enabled: true,
      entries: {
        // Saves conversation context to workspace/memory/ on session reset
        "session-memory": { enabled: true },
        // Logs all command events to ~/.openclaw/logs/commands.log (JSONL)
        "command-logger": { enabled: true },
        // Runs BOOT.md instructions on gateway start
        "boot-md": { enabled: true },
      },
    },
  },

  // Message queue: interrupt mode cancels any active run when a new message
  // arrives in the same session. This kills ghost runs left over from HTTP
  // timeouts — instead of the new message queueing behind a stale 600s run,
  // the ghost is aborted and the new message processes immediately.
  messages: {
    queue: {
      mode: "interrupt",
    },
  },

  // No external messaging channels — MultiClaw is the channel
  channels: {},
}
